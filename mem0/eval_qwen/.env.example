# Eval Qwen (Tinker backbone + Qwen3-30B-A3B) — 与 locomo_10_samples_with_stats 输出一致：time, log, f1, bleu, 花费
# 复制为 .env 并填入 Tinker API Key

# Tinker API（显式使用 Tinker，backbone 从 AWS Bedrock Claude 改为 Tinker）
# 文档: https://tinker-docs.thinkingmachines.ai/compatible-apis/openai
TINKER_BASE_URL=...
TINKER_API_KEY=...

# 模型（add 与 search 阶段均使用）
MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# 本地 Qdrant 与 embedder（与 evaluation 一致）
EMBEDDER_MODEL=BAAI/bge-m3
# MEM0_DIR 由各 run_*.py 设为 eval_qwen/results/<dataset>/.qdrant_run

# 不设 MEM0_API_KEY，使用本地 Memory + Tinker/Qwen

# 可选：兼容旧配置，若已设 OPENAI_BASE_URL/OPENAI_API_KEY 也会被使用
# OPENAI_BASE_URL=...
# OPENAI_API_KEY=...

# 可选：Tinker/Qwen 单价（$/1M tokens），用于费用估算；不设则用默认 3.0 / 15.0
# UNIT_PRICE_INPUT_PER_1M=0.5
# UNIT_PRICE_OUTPUT_PER_1M=2.0
