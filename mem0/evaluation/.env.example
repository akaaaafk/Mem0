# Mem0 云端 API（可选，不设则用本地 Memory）
# MEM0_API_KEY=your_mem0_api_key
# MEM0_ORGANIZATION_ID=your_org_id
# MEM0_PROJECT_ID=your_project_id

# 本地模式：embedder + LLM 都用本地，无需 MEM0 API
EMBEDDER_MODEL=BAAI/bge-m3
LLM_MODEL=llama3.2
# OLLAMA_BASE_URL=http://localhost:11434  # 可选
# EMBEDDER_DIMS=1024  # 可选，bge-m3 默认 1024

# 回答问题时用的模型（evaluation 里用 OpenAI 接口生成答案，可换成兼容接口的 Ollama）
MODEL=gpt-4o-mini
# 若用 OpenAI：OPENAI_API_KEY=sk-...
